#!/bin/bash

# --- Only display when SSH login ---
PARENT_PROC=$(ps -p $PPID -o comm= 2>/dev/null | tr -d ' ')
if [[ "$PARENT_PROC" != "sshd" ]]; then
    return 0 2>/dev/null || exit 0
fi

clear

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

T_OUT="timeout 0.5s"

# --- Discovery Functions ---

check_selinux() {
    if [[ -f /sys/fs/selinux/enforce ]]; then
        [[ $(cat /sys/fs/selinux/enforce) -eq 0 ]] && printf "${RED}%-18s${NC} : Permissive/Disabled (WARNING)\n" "SELinux"
    fi
}

check_exports() {
    if [[ -s /proc/exports ]] || [[ -s /var/lib/nfs/etab ]]; then
        printf "${YELLOW}%-18s${NC} : Active NFS exports detected\n" "NFS Exports"
    fi
}

check_nfsv4_acls() {
    if grep -q "nfs4" /proc/mounts 2>/dev/null; then
        if command -v nfs4_getfacl >/dev/null 2>&1; then
            printf "${GREEN}%-18s${NC} : Active & Tools installed\n" "NFSv4 ACLs"
        else
            printf "${YELLOW}%-18s${NC} : Active (Missing nfs4-acl-tools)\n" "NFSv4 ACLs"
        fi
    fi
}

check_failed_services() {
    local failed=$($T_OUT systemctl list-units --state=failed --legend=no 2>/dev/null | wc -l)
    [[ "$failed" -gt 0 ]] && printf "${RED}%-18s${NC} : %s failed units\n" "Services" "$failed"
}

check_middleware() {
    if $T_OUT pgrep -af "org\.jboss|jboss\.modules" >/dev/null 2>&1; then
        printf "${GREEN}%-18s${NC} : JBoss/Wildfly (Running)\n" "Middleware"
    fi

    if $T_OUT pgrep -af "org\.apache\.catalina\.startup\.Bootstrap" >/dev/null 2>&1; then
        printf "${GREEN}%-18s${NC} : Tomcat (Running)\n" "Middleware"
    fi
}

# --- Main Display ---

FULL_HOSTNAME=$($T_OUT hostname -f 2>/dev/null || hostname)

echo -e "${CYAN}====================================================${NC}"
echo -e "  ${YELLOW}SYSTEM STATUS - ${FULL_HOSTNAME}${NC}"
echo -e "${CYAN}====================================================${NC}"

printf "${GREEN}%-18s${NC} : %s\n" "OS" "$(cat /etc/redhat-release 2>/dev/null)"
printf "${GREEN}%-18s${NC} : %s\n" "Uptime" "$(uptime -p 2>/dev/null)"
printf "${GREEN}%-18s${NC} : %s session(s)\n" "Logged Users" "$($T_OUT who | wc -l)"
printf "${GREEN}%-18s${NC} : %s\n" "IP Address" "$($T_OUT hostname -I | awk '{print $1}')"
printf "${GREEN}%-18s${NC} : %s (Cores: %s)\n" "Load Average" "$(cut -d' ' -f1-3 /proc/loadavg)" "$(nproc)"
free -h | awk '/^Mem:/ {printf "\033[0;32m%-18s\033[0m : %s / %s\n", "Memory", $3, $2}'

# --- Dynamic Alerts & Middleware ---
ALERTS=$(
    check_selinux
    check_exports
    check_nfsv4_acls
    check_failed_services
    check_middleware
    $T_OUT df -h / 2>/dev/null | awk 'NR==2 {gsub("%","",$5); if($5 > 90) printf "\033[0;31m%-18s\033[0m : %s%% used\n", "Disk Alert (/)", $5}'
)

if [[ -n "$ALERTS" ]]; then
    echo -e "${CYAN}----------------------------------------------------${NC}"
    echo -e "$ALERTS"
fi

echo -e "${CYAN}====================================================${NC}"